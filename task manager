<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<title>Improved To-Do App</title>
<style>
body {
    font-family: Arial;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    text-align: center;
    padding-top: 50px;
}.container { background: rgba(255,255,255,0.1); padding: 20px; border-radius: 15px; width: 320px; margin: auto; }

input { padding: 10px; width: 65%; border-radius: 10px; border: none; outline: none; }

button { padding: 10px; border: none; border-radius: 10px; background: #00c9a7; color: white; cursor: pointer; margin-left: 5px; }

li { list-style: none; background: rgba(0,0,0,0.3); margin: 10px; padding: 10px; border-radius: 10px; display: flex; justify-content: space-between; align-items: center; }

.task-text { flex: 1; cursor: pointer; }

.completed { text-decoration: line-through; opacity: 0.6; }

.small-btn { margin-left: 5px; background: #ff4d4d; }

.edit-btn { background: #ffd166; color: black; } </style>

</head><body><div class="container">
    <h2>📝 To-Do List</h2><input id="taskInput" placeholder="Add task..." onkeydown="if(event.key==='Enter') addTask()">
<button onclick="addTask()">Add</button>

<ul id="list"></ul>

</div><script>
let tasks = JSON.parse(localStorage.getItem("tasks")) || [];

function save(){
    localStorage.setItem("tasks", JSON.stringify(tasks));
}

function showTasks(){
    let list = document.getElementById("list");
    list.innerHTML = "";

    if(tasks.length === 0){
        list.innerHTML = "<p>No tasks yet 🚀</p>";
        return;
    }

    tasks.forEach((task, index)=>{
        let li = document.createElement("li");

        li.innerHTML = `
            <span class="task-text ${task.done ? 'completed' : ''}" onclick="toggleTask(${index})">
                ${task.text}
            </span>

            <div>
                <button class="edit-btn" onclick="editTask(${index})">✏️</button>
                <button class="small-btn" onclick="deleteTask(${index})">❌</button>
            </div>
        `;

        list.appendChild(li);
    });
}

function addTask(){
    let input = document.getElementById("taskInput");

    if(input.value.trim() === "") return;

    tasks.push({
        text: input.value,
        done: false
    });

    input.value = "";
    save();
    showTasks();
}

function deleteTask(i){
    tasks.splice(i,1);
    save();
    showTasks();
}

function toggleTask(i){
    tasks[i].done = !tasks[i].done;
    save();
    showTasks();
}

function editTask(i){
    let newText = prompt("Edit task:", tasks[i].text);
    if(newText && newText.trim() !== ""){
        tasks[i].text = newText;
        save();
        showTasks();
    }
}

showTasks();
</script></body>
</html>
